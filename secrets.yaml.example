# Copy this file to secrets.yaml (which is gitignored) and fill in real values:
#   cp secrets.yaml.example secrets.yaml

# Web UI + OTA-upload login (the UI is reachable over Tailscale — use a strong password)
web_username: "admin"
web_password: "choose-a-strong-password"

# Home Assistant native API encryption key.  Generate with:
#   openssl rand -base64 32
api_encryption_key: "REPLACE-WITH-32-BYTE-BASE64-KEY"

# OTA update password.  Generate with:
#   openssl rand -hex 16
ota_password: "REPLACE-WITH-A-PASSWORD"

# CT002 presented MAC. "" = mirror each battery's own CT MAC (default).
# Or a fixed 12-hex MAC (':' / '-' separators allowed), e.g. "28848553928c".
ct_mac: ""

# MQTT broker (Home Assistant's Mosquitto), reached over Tailscale.
# Use the HA host's Tailscale IP (most reliable on the ESP) or its MagicDNS name.
mqtt_broker: "100.x.y.z"
mqtt_username: "your-mqtt-username"
mqtt_password: "your-mqtt-password"

# Tailscale auth key — admin console → Settings → Keys → Generate auth key
# (reusable + ephemeral recommended).
tailscale_auth_key: "tskey-auth-..."

# Optional static IP — only needed if you uncomment manual_ip in
# astrameter-ct002-dsmr.yaml. Leave commented to use DHCP.
# static_ip: "192.168.1.50"
# gateway: "192.168.1.1"
# subnet: "255.255.255.0"
# dns1: "192.168.1.1"
